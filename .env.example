# Senha do SA para os containers SQL Server
# Requisitos: mínimo 8 caracteres, maiúscula, minúscula, número e símbolo
SA_PASSWORD=Arquitetura@2025!

# Credenciais do RabbitMQ (Management UI: http://localhost:15672)
RABBITMQ_USER=admin
RABBITMQ_PASS=Arquitetura@2025!

# URLs das APIs — usadas apenas para dotnet run local (fora do Docker)
# Em Docker, o Nginx roteia /api/* internamente via nome de serviço
# VITE_API_PRODUTOS=http://localhost:5001
# VITE_API_PEDIDOS=http://localhost:5002
